<Window x:Class="TinyBongo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BongoCat2"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Grid ClipToBounds="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="256*" />
            <RowDefinition Height="42*" />
        </Grid.RowDefinitions>

        <Image x:Name="CatImage"
           Grid.Row="0"
           RenderOptions.BitmapScalingMode="HighQuality"
           SnapsToDevicePixels="True"
           Stretch="Uniform" />

        <Border x:Name="CounterBorder"
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,-15,0,0"
            Background="White"
            BorderBrush="Black"
            BorderThickness="2"
            CornerRadius="12"
            Padding="10,3"
            MinHeight="26">
            <TextBlock x:Name="CounterText"
                   Text="0"
                   FontFamily="Comic Sans MS"
                   FontWeight="Bold"
                   FontSize="15"
                   Foreground="Black"
                   TextAlignment="Center"
                   VerticalAlignment="Center"
                   LineHeight="18"/>
        </Border>
    </Grid>

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Reset Counter" Click="ResetCounter_Click" />
        </ContextMenu>
    </Window.ContextMenu>
</Window>
